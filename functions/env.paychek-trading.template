# Copier en LOCAL vers functions/.env.paychek-trading (fichier ignore par git).
# Ne pas lancer les invites du CLI en meme temps que ce fichier.
#
# PAYCHEK_SMTP_PASSWORD ne va pas ici (secret Firebase).

# --- Principal : Resend (cle re_ depuis https://resend.com/api-keys) ---
# Domaine paychek.pro doit etre "Verified" sur https://resend.com/domains
PAYCHEK_RESEND_API_KEY=

PAYCHEK_MAIL_FROM=contact@paychek.pro
PAYCHEK_MAIL_BCC=contact@paychek.pro

# --- Secours SMTP (si Resend echoue ; laisser vide pour Resend seul) ---
PAYCHEK_SMTP_HOST=
PAYCHEK_SMTP_PORT=587
PAYCHEK_SMTP_SECURE=false
PAYCHEK_SMTP_USER=

# --- Stripe (abonnement web) — secrets Firebase, pas ce fichier en prod ---
# firebase functions:secrets:set PAYCHEK_STRIPE_SECRET_KEY      # sk_live_… ou sk_test_…
# firebase functions:secrets:set PAYCHEK_STRIPE_WEBHOOK_SECRET   # whsec_… (Stripe > Webhooks)
# Webhook HTTPS (POST), region europe-west1 :
#   https://europe-west1-paychek-trading.cloudfunctions.net/paychekStripeWebhook
# Evenement : checkout.session.completed
# L’app web ajoute client_reference_id = uid Firebase sur l’URL du Payment Link.
#
# URL paywall sans dart-define : Firestore paychek_app_config/billing (console admin).
